# ─────────────────────────────────────────────────────────
# LexRD Backend — Variables de entorno
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena los valores reales en el .env
#   3. Nunca subas .env a GitHub (ya está en .gitignore)
# ─────────────────────────────────────────────────────────

# PostgreSQL (Docker local)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=lexrd_backend
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Seeder: pon "true" para indexar PDFs al arrancar, "false" para saltarlo
APP_SEEDER_ENABLED=true

# API Key para proteger endpoints /api/**
API_KEY_FILTER=your_secret_api_key_here

# URL del frontend (para CORS en Docker)
FRONTEND_URL=http://localhost:3000

