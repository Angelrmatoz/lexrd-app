# ─────────────────────────────────────────────────────────
# LexRD Backend — Variables de entorno
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena los valores reales en el .env
#   3. Nunca subas .env a GitHub (ya está en .gitignore)
# ─────────────────────────────────────────────────────────

# ===================================================================
# PARA LOCAL (Docker PostgreSQL)
# Uso: docker compose -f docker-compose.local.yml up -d
# Backend se ejecuta desde IntelliJ con perfil "local"
# ===================================================================

DB_PASSWORD=1834569

# ===================================================================
# PARA DESARROLLO (Supabase con backend en Docker)
# Uso: docker compose -f docker-compose.dev.yml up -d
# ===================================================================

# Supabase (Session Pooler - IPv4)
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-[REGION].pooler.supabase.com:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres.[TU-PROYECTO]
SPRING_DATASOURCE_PASSWORD=your_supabase_password

# IA Configuration
GEMINI_API_KEY=your_gemini_api_key
OPENROUTER_API_KEY=your_openrouter_api_key

# ===================================================================
# PARA PRODUCCIÓN (Azure Container Apps)
# Uso: docker compose up -d (referencia)
# ===================================================================

# Supabase (mismas variables que dev)
# SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-[REGION].pooler.supabase.com:5432/postgres
# SPRING_DATASOURCE_USERNAME=postgres.[TU-PROYECTO]
# SPRING_DATASOURCE_PASSWORD=your_supabase_password

# Security & Frontend
API_KEY_FILTER=your_secret_api_key_here
FRONTEND_URL=https://tu-dominio.com

# IA Configuration
# GEMINI_API_KEY=your_gemini_api_key
# OPENROUTER_API_KEY=your_openrouter_api_key
