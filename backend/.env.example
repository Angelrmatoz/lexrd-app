# ─────────────────────────────────────────────────────────
# LexRD Backend — Variables de entorno locales
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena los valores reales en el .env
#   3. Nunca subas .env a GitHub (ya está en .gitignore)
# ─────────────────────────────────────────────────────────

# PostgreSQL (Docker local)
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# Seeder: pon "true" para indexar PDFs al arrancar, "false" para saltarlo
APP_SEEDER_ENABLED=

# Supabase (Session Pooler - IPv4)
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# IA Configuration
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Security & Frontend
API_KEY_FILTER=
FRONTEND_URL=