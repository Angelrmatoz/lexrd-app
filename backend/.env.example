# ─────────────────────────────────────────────────────────
# LexRD Backend — Variables de entorno locales
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena los valores reales en el .env
#   3. Nunca subas .env a GitHub (ya está en .gitignore)
# ─────────────────────────────────────────────────────────

# PostgreSQL (Docker local)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=lexrd_backend
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Google Gemini (Embeddings)
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter (LLM gratuito: Llama, Qwen, GPT, etc.)
# Obtener en: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Seeder: pon "true" para indexar PDFs al arrancar, "false" para saltarlo
APP_SEEDER_ENABLED=true
